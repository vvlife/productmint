{
  "framework": "nextjs",
  "buildCommand": "npx next build --webpack",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/crawl",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/daily-collect",
      "schedule": "0 9 * * *"
    }
  ]
}
